{
  "name": "northlight",
  "version": "0.8.31",
  "productName": "Northlight",
  "description": "A steel-fast macOS launcher built with Electron, React, and Mantine.",
  "main": "dist-electron/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev --watch",
    "design": "node scripts/run-design.mjs",
    "build": "npm run typecheck && vite build && electron-vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "verify": "npm run lint && npm run typecheck && npm run test:unit"
  },
  "keywords": [
    "electron",
    "launcher",
    "macos",
    "spotlight"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mantine/core": "^7.17.3",
    "@mantine/hooks": "^7.17.3",
    "@tabler/icons-react": "^3.31.0",
    "convert-units": "^2.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^3.0.0",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.14.1",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^35.1.4",
    "electron-vite": "^3.0.0",
    "eslint": "^9.23.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.4",
    "vitest": "^3.1.1"
  }
}

<!doctype html>
<html lang="en">
  <head>
    <script type="module">import { injectIntoGlobalHook } from "/@react-refresh";
injectIntoGlobalHook(window);
window.$RefreshReg$ = () => {};
window.$RefreshSig$ = () => (type) => type;</script>

    <script type="module" src="/@vite/client"></script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Northlight Launcher Current View</title>
    <style>
      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
      }

      body {
        min-height: 108vh;
        display: grid;
        place-items: center;
        gap: 24px;
        padding: 32px;
        background:
          radial-gradient(circle at top left, rgba(115, 142, 168, 0.16), transparent 28%),
          linear-gradient(180deg, #10161d, #0a0f14);
        color: #f5f7fa;
        font-family: Inter, "SF Pro Display", ui-sans-serif, system-ui, sans-serif;
      }

      .meta {
        width: 1120px;
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 20px;
      }

      .title {
        font-size: 0.95rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .note {
        color: rgba(243, 246, 250, 0.66);
        font-size: 0.86rem;
      }

      .frame {
        width: 1120px;
        height: 760px;
        border: 0;
        border-radius: 10px;
        overflow: hidden;
        display: block;
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.34);
      }
    </style>
  </head>
  <body>
    <header class="meta">
      <div class="title">Launcher Mockup</div>
      <div class="note">Exact launcher viewport: 1120×760.</div>
    </header>
    <iframe class="frame" src="/design/launcher-current-view-frame.html" title="Northlight launcher current view"></iframe>
    <script type="module" src="/design/launcher-current-view.html?html-proxy&index=0.js"></script>
  </body>
</html>
